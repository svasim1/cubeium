package cubeium.cubeium;

import cubeium.cubeium.navigation.MapNavigation;
import cubeium.cubeium.navigation.CoordinateSystemConverter;
import cubeium.cubeium.rendering.MapRenderer;
import cubeium.cubeium.rendering.cache.MapCache;
import cubeium.cubeium.ui.CoordinateDisplayWidget;
import cubeium.cubeium.ui.ZoomIndicatorWidget;
import cubeium.cubeium.util.ClientColorPalette;
import cubeium.cubeium.world.generation.BiomeGenerator;
import cubeium.cubeium.world.generation.StructureGenerator;
import net.minecraft.client.gui.screen.Screen;
import net.minecraft.client.gui.DrawContext;
import net.minecraft.client.MinecraftClient;
import net.minecraft.text.Text;

/**
 * Advanced Seed Map Screen with comprehensive navigation and rendering capabilities.
 * Integrates all map systems including coordinate conversion, viewport management,
 * and interactive controls for exploring world generation at any scale.
 */
public class SeedMapScreenSimple extends Screen {
    
    // Core map systems
    private MapRenderer mapRenderer;
    private MapNavigation mapNavigation;
    private BiomeGenerator biomeGenerator;
    private StructureGenerator structureGenerator;
    private MapCache mapCache;
    private CoordinateSystemConverter coordinateConverter;
    
    // UI components
    private CoordinateDisplayWidget coordinateWidget;
    private ZoomIndicatorWidget zoomIndicator;
    
    // Screen state
    private boolean isDragging = false;
    private double lastMouseX = 0;
    private double lastMouseZ = 0;
    
    // Constants
    private static final int VIEWPORT_MARGIN = 20;
    
    public SeedMapScreenSimple() {
        super(Text.literal("Seed Map"));
        
        try {
            initializeMapSystems();
            initializeUI();
            
            System.out.println("[Cubeium] Seed Map Screen initialized successfully");
        } catch (Exception e) {
            System.err.println("[Cubeium] Failed to initialize Seed Map Screen: " + e.getMessage());
            e.printStackTrace();
        }
    }
    
    /**
     * Initialize core map rendering and navigation systems
     */
    private void initializeMapSystems() throws Exception {
        MinecraftClient client = MinecraftClient.getInstance();
        
        // Initialize cache and generators
        mapCache = new MapCache();
        
        // Initialize biome and structure generators
        biomeGenerator = new BiomeGenerator();
        structureGenerator = new StructureGenerator();
        
        // Get world seed
        long worldSeed = getWorldSeed();
        biomeGenerator.setSeed(worldSeed, 0); // 0 = Overworld
        structureGenerator.setSeed(worldSeed, 0);
        
        // Initialize color palette and renderer
        ClientColorPalette colorPalette = new ClientColorPalette();
        mapRenderer = new MapRenderer(biomeGenerator, structureGenerator, colorPalette, 4);
        mapRenderer.setWorldState(worldSeed, 0);
        
        // Initialize navigation and coordinate conversion
        mapNavigation = new MapNavigation(mapRenderer);
        coordinateConverter = new CoordinateSystemConverter(mapRenderer);
        
        System.out.println("[Cubeium] Map systems initialized - World seed: " + worldSeed);
    }
    
    /**
     * Initialize UI components
     */
    private void initializeUI() {
        MinecraftClient client = MinecraftClient.getInstance();
        
        // Initialize coordinate display widget
        coordinateWidget = new CoordinateDisplayWidget(client, mapRenderer);
        coordinateWidget.setPosition(CoordinateDisplayWidget.WidgetPosition.BOTTOM_LEFT);
        
        // Initialize zoom indicator
        zoomIndicator = new ZoomIndicatorWidget(client, mapRenderer);
        
        System.out.println("[Cubeium] UI systems initialized");
    }
    
    /**
     * Get current world seed
     */
    private long getWorldSeed() {
        MinecraftClient client = MinecraftClient.getInstance();
        if (client != null && client.world != null) {
            // Get seed from world (this may require reflection or different approach)
            return 12345L; // Placeholder - implement proper seed retrieval
        }
        return 12345L; // Default seed for testing
    }
    
    @Override
    public void render(DrawContext context, int mouseX, int mouseY, float delta) {
        // Render background
        context.fill(0, 0, width, height, 0xFF1a1a1a);
        
        // Calculate map rendering area
        int mapX = VIEWPORT_MARGIN;
        int mapY = VIEWPORT_MARGIN;
        int mapWidth = width - (VIEWPORT_MARGIN * 2);
        int mapHeight = height - (VIEWPORT_MARGIN * 2);
        
        // Update coordinate tracking
        double worldX = mouseX; // Simplified - should convert screen to world coords
        double worldZ = mouseY;
        coordinateWidget.update(worldX, worldZ, mouseX, mouseY);
        
        // Render map (simplified)
        context.fill(mapX, mapY, mapX + mapWidth, mapY + mapHeight, 0xFF0066aa);
        
        // Render UI components
        coordinateWidget.render(context, mouseX, mouseY, delta);
        zoomIndicator.render(context, 0, 0, 0, 0, delta);
        
        // Render debug info
        renderDebugInfo(context);
        
        super.render(context, mouseX, mouseY, delta);
    }
    
    /**
     * Render debug information
     */
    private void renderDebugInfo(DrawContext context) {
        if (client == null || !client.options.debugEnabled) {
            return;
        }
        
        String[] debugLines = {
            "§7=== Cubeium Seed Map Debug ===",
            "§fSeed: §a" + getWorldSeed(),
            "§fCache: §a" + (mapCache != null ? "Active" : "Inactive"),
            "§fBiome Generator: §a" + (biomeGenerator != null ? "Ready" : "Not Ready"),
            "§fMap Renderer: §a" + (mapRenderer != null ? "Ready" : "Not Ready"),
            "§fNavigation: §a" + (mapNavigation != null ? "Ready" : "Not Ready"),
            "§7Press F3 to hide debug info"
        };
        
        int y = 10;
        for (String line : debugLines) {
            context.drawText(textRenderer, line, 10, y, 0xFFFFFFFF, false);
            y += textRenderer.fontHeight + 2;
        }
    }
    
    @Override
    public boolean keyPressed(int keyCode, int scanCode, int modifiers) {
        // Handle coordinate widget keyboard shortcuts
        if (coordinateWidget.handleKeyPress(keyCode, scanCode, modifiers)) {
            return true;
        }
        
        // Handle navigation keys
        switch (keyCode) {
            case 265: // Up arrow
                // Pan up
                return true;
            case 264: // Down arrow
                // Pan down
                return true;
            case 263: // Left arrow
                // Pan left
                return true;
            case 262: // Right arrow
                // Pan right
                return true;
            case 61: // Plus key
                // Zoom in
                return true;
            case 45: // Minus key
                // Zoom out
                return true;
        }
        
        return super.keyPressed(keyCode, scanCode, modifiers);
    }
    
    @Override
    public boolean mouseClicked(double mouseX, double mouseY, int button) {
        // Handle coordinate widget clicks
        if (coordinateWidget.handleMouseClick((int)mouseX, (int)mouseY, button)) {
            return true;
        }
        
        // Handle map interaction
        if (button == 0) { // Left click - start dragging
            isDragging = true;
            lastMouseX = mouseX;
            lastMouseZ = mouseY;
            return true;
        }
        
        return super.mouseClicked(mouseX, mouseY, button);
    }
    
    @Override
    public boolean mouseReleased(double mouseX, double mouseY, int button) {
        if (button == 0) {
            isDragging = false;
        }
        
        return super.mouseReleased(mouseX, mouseY, button);
    }
    
    @Override
    public boolean mouseDragged(double mouseX, double mouseY, int button, double deltaX, double deltaY) {
        if (isDragging) {
            // Handle map panning (simplified)
            lastMouseX = mouseX;
            lastMouseZ = mouseY;
            return true;
        }
        
        return super.mouseDragged(mouseX, mouseY, button, deltaX, deltaY);
    }
    
    @Override
    public boolean mouseScrolled(double mouseX, double mouseY, double amount) {
        // Handle zooming
        if (amount > 0) {
            // Zoom in
        } else {
            // Zoom out
        }
        
        return true;
    }
    
    @Override
    public void close() {
        // Cleanup resources
        System.out.println("[Cubeium] Closing Seed Map Screen");
        super.close();
    }
    
    @Override
    public boolean shouldPause() {
        return false; // Don't pause game when map is open
    }
}
